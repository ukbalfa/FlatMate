rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if the requesting user is an admin
    function isAdmin() {
      return request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Users: self-read/write, admin-read-all, admin-delete
    match /users/{userId} {
      allow read: if request.auth != null
        && (request.auth.uid == userId || isAdmin());
      allow create: if request.auth != null;
      allow update: if request.auth != null
        && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
    }

    // Expenses: authenticated read/write
    match /expenses/{docId} {
      allow read, write: if request.auth != null;
    }

    // Tasks: authenticated read/write
    match /tasks/{docId} {
      allow read, write: if request.auth != null;
    }

    // Cleaning schedule: authenticated read/write
    match /cleaning/{docId} {
      allow read, write: if request.auth != null;
    }

    // Announcements: authenticated read/write
    match /announcements/{docId} {
      allow read, write: if request.auth != null;
    }

    // Settlements: authenticated read/write
    match /settlements/{docId} {
      allow read, write: if request.auth != null;
    }

    // Recurring expenses: authenticated read/write
    match /recurringExpenses/{docId} {
      allow read, write: if request.auth != null;
    }

    // Notifications: user can only read/write their own
    match /notifications/{docId} {
      allow read: if request.auth != null
        && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null
        && resource.data.userId == request.auth.uid;
    }

    // Settings: authenticated read/write
    match /settings/{docId} {
      allow read, write: if request.auth != null;
    }
  }
}
